<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="PairEd123.Views.RequestsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:PairEd123.Models"
    x:Name="RootPage"
    Title="Requests"
    BackgroundColor="#F8FAFC">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <!-- Tab Buttons -->
            <HorizontalStackLayout Spacing="12" IsVisible="{Binding IsTutor}" HorizontalOptions="Center">
                <Button Text="My Requests"
                        Command="{Binding ShowSentTabCommand}"
                        BackgroundColor="#D8121B"
                        TextColor="#FFFFFF"
                        CornerRadius="20"
                        FontFamily="Segoe UI"
                        FontAttributes="Bold"
                        HeightRequest="40"/>
                <Button Text="Incoming"
                        Command="{Binding ShowIncomingTabCommand}"
                        BackgroundColor="#0E1626"
                        TextColor="#FFFFFF"
                        CornerRadius="20"
                        FontFamily="Segoe UI"
                        FontAttributes="Bold"
                        HeightRequest="40"/>
            </HorizontalStackLayout>

            <!-- Loading Indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#D8121B"/>

            <!-- Status Message -->
            <Label Text="{Binding StatusMessage}"
                   FontFamily="Segoe UI"
                   TextColor="#D8121B"
                   FontSize="14"
                   HorizontalOptions="Center"/>

            <!-- Sent Requests -->
            <CollectionView ItemsSource="{Binding SentRequests}" IsVisible="{Binding IsSentTabActive}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="14"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:RequestDisplay">
                        <Frame BackgroundColor="#FFFFFF"
                               BorderColor="#E2E8F0"
                               CornerRadius="12"
                               Padding="16"
                               HasShadow="True"
                               Margin="0,6">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding OtherPartyName}"
                                       FontFamily="Segoe UI"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#0E1626"/>
                                <Label Text="{Binding Subject}"
                                       FontFamily="Segoe UI"
                                       FontSize="14"
                                       TextColor="#64748B"/>
                                <Label Text="{Binding PreferredDate, StringFormat='{0:MMM d, yyyy h:mm tt}'}"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       TextColor="#64748B"/>
                                <Label Text="{Binding Status}"
                                       FontFamily="Segoe UI"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#0E1626"/>
                                <Label Text="{Binding RejectionReason, StringFormat='Reason: {0}'}"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       TextColor="#D8121B"/>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Incoming Requests -->
            <CollectionView ItemsSource="{Binding IncomingRequests}" IsVisible="{Binding IsIncomingTabActive}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="14"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:RequestDisplay">
                        <Frame BackgroundColor="#FFFFFF"
                               BorderColor="#E2E8F0"
                               CornerRadius="12"
                               Padding="16"
                               HasShadow="True"
                               Margin="0,6">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding OtherPartyName}"
                                       FontFamily="Segoe UI"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#0E1626"/>
                                <Label Text="{Binding Subject}"
                                       FontFamily="Segoe UI"
                                       FontSize="14"
                                       TextColor="#64748B"/>
                                <Label Text="{Binding PreferredDate, StringFormat='{0:MMM d, yyyy h:mm tt}'}"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       TextColor="#64748B"/>
                                <Label Text="{Binding Status}"
                                       FontFamily="Segoe UI"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#0E1626"/>

                                <HorizontalStackLayout Spacing="12">
                                    <Button Text="Accept"
                                            Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.AcceptCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#0E1626"
                                            TextColor="#FFFFFF"
                                            CornerRadius="20"
                                            FontFamily="Segoe UI"
                                            FontAttributes="Bold"
                                            HeightRequest="36"/>
                                    <Button Text="Decline"
                                            Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.StartDeclineCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="Transparent"
                                            TextColor="#D8121B"
                                            BorderColor="#D8121B"
                                            BorderWidth="2"
                                            CornerRadius="20"
                                            FontFamily="Segoe UI"
                                            FontAttributes="Bold"
                                            HeightRequest="36"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Decline Prompt -->
            <Frame IsVisible="{Binding IsDeclinePromptVisible}"
                   BackgroundColor="#FFFFFF"
                   BorderColor="#E2E8F0"
                   CornerRadius="12"
                   Padding="16"
                   HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Reason for declining"
                           FontFamily="Segoe UI"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#0E1626"/>
                    <Entry Placeholder="Explain why you're declining"
                           Text="{Binding DeclineReasonText}"
                           FontFamily="Segoe UI"
                           TextColor="#0E1626"
                           PlaceholderColor="#64748B"/>
                    <HorizontalStackLayout Spacing="12">
                        <Button Text="Confirm Decline"
                                Command="{Binding ConfirmDeclineCommand}"
                                BackgroundColor="#D8121B"
                                TextColor="#FFFFFF"
                                CornerRadius="20"
                                FontFamily="Segoe UI"
                                FontAttributes="Bold"
                                HeightRequest="40"/>
                        <Button Text="Cancel"
                                Command="{Binding CancelDeclineCommand}"
                                BackgroundColor="Transparent"
                                TextColor="#0E1626"
                                BorderColor="#0E1626"
                                BorderWidth="2"
                                CornerRadius="20"
                                FontFamily="Segoe UI"
                                FontAttributes="Bold"
                                HeightRequest="40"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
