<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="PairEd123.Views.SearchPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:PairEd123.Models"
    x:Name="RootPage"
    Title="Search"
    BackgroundColor="#F8FAFC">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <!-- Search Bar -->
            <Frame BackgroundColor="#FFFFFF"
                   BorderColor="#E2E8F0"
                   CornerRadius="12"
                   Padding="12"
                   HasShadow="True">
                <Entry x:Name="SearchEntry"
                       Placeholder="Search tutors, subjects, or sessions..."
                       Text="{Binding QueryText}"
                       FontFamily="Segoe UI"
                       TextColor="#0E1626"
                       PlaceholderColor="#64748B"/>
            </Frame>

            <!-- Loading Indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#D8121B"/>

            <!-- Status Message -->
            <Label Text="{Binding StatusMessage}"
                   FontFamily="Segoe UI"
                   TextColor="#D8121B"
                   FontSize="14"
                   HorizontalOptions="Center"/>

            <!-- Search Results -->
            <CollectionView ItemsSource="{Binding SearchResults}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="14"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:SearchResultDisplay">
                        <Frame BackgroundColor="#FFFFFF"
                               BorderColor="#E2E8F0"
                               CornerRadius="12"
                               Padding="16"
                               HasShadow="True"
                               Margin="0,6">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding Name}"
                                       FontFamily="Segoe UI"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#0E1626"/>
                                <Label Text="{Binding Subject}"
                                       FontFamily="Segoe UI"
                                       FontSize="14"
                                       TextColor="#64748B"/>
                                <Label Text="{Binding Availability}"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       TextColor="#64748B"/>
                                <HorizontalStackLayout Spacing="12">
                                    <Button Text="Request"
                                            Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.RequestCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#D8121B"
                                            TextColor="#FFFFFF"
                                            CornerRadius="20"
                                            FontFamily="Segoe UI"
                                            FontAttributes="Bold"
                                            HeightRequest="36"/>
                                    <Button Text="Message"
                                            Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.MessageCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#0E1626"
                                            TextColor="#FFFFFF"
                                            CornerRadius="20"
                                            FontFamily="Segoe UI"
                                            FontAttributes="Bold"
                                            HeightRequest="36"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
