<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="PairEd123.Views.AdminSkillsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:PairEd123.Models"
    Title="Manage Skills"
    BackgroundColor="#F8FAFC">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <!-- New Skill Entry -->
            <Frame BackgroundColor="#FFFFFF"
                   BorderColor="#E2E8F0"
                   CornerRadius="12"
                   Padding="12"
                   HasShadow="True">
                <Entry x:Name="NewSkillEntry"
                       Placeholder="New skill name (e.g. Chemistry)"
                       Text="{Binding NewSkillName}"
                       FontFamily="Segoe UI"
                       TextColor="#0E1626"
                       PlaceholderColor="#64748B"/>
            </Frame>

            <!-- Add Skill Button -->
            <Button x:Name="AddSkillBtn"
                    Text="Add Skill"
                    Command="{Binding AddSkillCommand}"
                    BackgroundColor="#D8121B"
                    TextColor="#FFFFFF"
                    CornerRadius="20"
                    FontFamily="Segoe UI"
                    FontAttributes="Bold"
                    HeightRequest="48"/>

            <!-- Loading Indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#D8121B"/>

            <!-- Status Message -->
            <Label Text="{Binding StatusMessage}"
                   FontFamily="Segoe UI"
                   TextColor="#D8121B"
                   FontSize="14"
                   HorizontalOptions="Center"/>

            <!-- Skills List -->
            <CollectionView ItemsSource="{Binding Skills}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="14"/>
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Skill">
                        <Frame BackgroundColor="#FFFFFF"
                               BorderColor="#E2E8F0"
                               CornerRadius="12"
                               Padding="12"
                               HasShadow="True">
                            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                                <!-- Skill Name -->
                                <Label Grid.Column="0"
                                       Text="{Binding SkillName}"
                                       FontFamily="Segoe UI"
                                       FontSize="16"
                                       TextColor="#0E1626"
                                       VerticalOptions="Center"/>

                                <!-- Delete Button -->
                                <Button Grid.Column="1"
                                        x:Name="DeleteSkillBtn"
                                        Text="Delete"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteSkillCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="Transparent"
                                        TextColor="#D8121B"
                                        BorderColor="#D8121B"
                                        BorderWidth="2"
                                        CornerRadius="20"
                                        FontFamily="Segoe UI"
                                        FontAttributes="Bold"
                                        HeightRequest="36"
                                        Padding="12,0"/>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
