<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="PairEd123.Views.SessionsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:PairEd123.Models"
    x:Name="RootPage"
    Title="Sessions">
    <VerticalStackLayout Padding="16" Spacing="10">

        <HorizontalStackLayout Spacing="10">
            <Button Text="Upcoming" Command="{Binding ShowUpcomingTabCommand}" />
            <Button Text="Completed" Command="{Binding ShowCompletedTabCommand}" />
            <Button Text="Cancelled" Command="{Binding ShowCancelledTabCommand}" />
        </HorizontalStackLayout>

        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
        <Label Text="{Binding StatusMessage}" TextColor="Red" />

        <CollectionView ItemsSource="{Binding UpcomingSessions}" IsVisible="{Binding IsUpcomingTabActive}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:SessionDisplay">
                    <Frame Padding="12" Margin="0,4" CornerRadius="10" HasShadow="False" BorderColor="LightGray">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding OtherPartyName}" FontAttributes="Bold" />
                            <Label Text="{Binding Subject}" />
                            <Label Text="{Binding ScheduledTime, StringFormat='{0:MMM d, yyyy h:mm tt}'}" FontSize="12" TextColor="Gray" />

                            <HorizontalStackLayout Spacing="10">
                                <Button Text="Mark Complete"
                                        IsVisible="{Binding IsTutorView}"
                                        Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.CompleteCommand}"
                                        CommandParameter="{Binding .}" />
                                <Button Text="Cancel"
                                        Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.StartCancelCommand}"
                                        CommandParameter="{Binding .}" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <CollectionView ItemsSource="{Binding CompletedSessions}" IsVisible="{Binding IsCompletedTabActive}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:SessionDisplay">
                    <Frame Padding="12" Margin="0,4" CornerRadius="10" HasShadow="False" BorderColor="LightGray">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding OtherPartyName}" FontAttributes="Bold" />
                            <Label Text="{Binding Subject}" />
                            <Label Text="{Binding ScheduledTime, StringFormat='{0:MMM d, yyyy h:mm tt}'}" FontSize="12" TextColor="Gray" />
                            <Label Text="Completed" FontSize="12" FontAttributes="Bold" TextColor="Green" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <CollectionView ItemsSource="{Binding CancelledSessions}" IsVisible="{Binding IsCancelledTabActive}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:SessionDisplay">
                    <Frame Padding="12" Margin="0,4" CornerRadius="10" HasShadow="False" BorderColor="LightGray">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding OtherPartyName}" FontAttributes="Bold" />
                            <Label Text="{Binding Subject}" />
                            <Label Text="{Binding ScheduledTime, StringFormat='{0:MMM d, yyyy h:mm tt}'}" FontSize="12" TextColor="Gray" />
                            <Label Text="Cancelled" FontSize="12" FontAttributes="Bold" TextColor="Red" />
                            <Label Text="{Binding CancellationReason, StringFormat='Reason: {0}'}" TextColor="Red" FontSize="12" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Frame IsVisible="{Binding IsCancelPromptVisible}" Padding="14" CornerRadius="10" BackgroundColor="#FFF3F3">
            <VerticalStackLayout Spacing="8">
                <Label Text="Reason for cancelling" FontAttributes="Bold" />
                <Entry Placeholder="Explain why you're cancelling" Text="{Binding CancelReasonText}" />
                <HorizontalStackLayout Spacing="10">
                    <Button Text="Confirm Cancel" Command="{Binding ConfirmCancelCommand}" />
                    <Button Text="Cancel" Command="{Binding CancelCancelCommand}" />
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Frame>

    </VerticalStackLayout>
</ContentPage>