<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PairEd123.Views.AdminDashboardPage"
             Title="Admin Dashboard">
    <VerticalStackLayout Padding="24" Spacing="16" VerticalOptions="Center">
        <Label Text="{Binding Greeting}" FontSize="22" HorizontalOptions="Center" />
        <Button Text="Manage Users" Command="{Binding GoToManageUsersCommand}" />
        <Button Text="Manage Skills" Command="{Binding GoToManageSkillsCommand}" />
        <Button Text="Reports" Command="{Binding GoToReportsCommand}" />
        <Button Text="Log Out" Command="{Binding LogoutCommand}"
                BackgroundColor="Transparent" TextColor="Red" />
    </VerticalStackLayout>
</ContentPage>