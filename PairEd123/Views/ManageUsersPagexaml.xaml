<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="PairEd123.Views.ManageUsersPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:PairEd123.Models"
    Title="Manage Users">
    <VerticalStackLayout Padding="20" Spacing="12">
        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
        <Label Text="{Binding StatusMessage}" TextColor="Green" />

        <CollectionView ItemsSource="{Binding Users}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:User">
                    <Frame Padding="12" CornerRadius="10" BorderColor="LightGray" Margin="0,4">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding DisplayName}" FontAttributes="Bold" />
                            <Label Text="{Binding Email}" FontSize="12" TextColor="Gray" />
                            <Picker ItemsSource="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RoleOptions}"
                                    SelectedItem="{Binding Role}" />
                            <Button Text="Save Role"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ChangeRoleCommand}"
                                    CommandParameter="{Binding .}" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>