<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PairEd123.Views.UserDashboardPage"
             Title="Dashboard"
             BackgroundColor="#F8FAFC">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20" VerticalOptions="Center">

            <!-- Profile Picture -->
            <Frame BackgroundColor="#FFFFFF"
                   BorderColor="#E2E8F0"
                   CornerRadius="40"
                   WidthRequest="80"
                   HeightRequest="80"
                   HorizontalOptions="Center"
                   HasShadow="True">
                <Image Source="{Binding ProfilePicturePath}"
                       HeightRequest="80"
                       WidthRequest="80"
                       Aspect="AspectFill"/>
            </Frame>

            <!-- Greeting -->
            <Label Text="{Binding Greeting}"
                   FontFamily="Segoe UI"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#0E1626"
                   HorizontalOptions="Center"/>

            <!-- Role Label -->
            <Label Text="{Binding RoleLabel}"
                   FontFamily="Segoe UI"
                   FontSize="14"
                   TextColor="#64748B"
                   HorizontalOptions="Center"/>

            <!-- Navigation Buttons -->
            <Button x:Name="ProfileBtn"
                    Text="My Profile"
                    Command="{Binding GoToProfileCommand}"
                    BackgroundColor="#D8121B"
                    TextColor="#FFFFFF"
                    CornerRadius="20"
                    FontFamily="Segoe UI"
                    FontAttributes="Bold"
                    HeightRequest="48"/>

            <Button x:Name="SearchBtn"
                    Text="Find a Tutor"
                    Command="{Binding GoToSearchCommand}"
                    BackgroundColor="#0E1626"
                    TextColor="#FFFFFF"
                    CornerRadius="20"
                    FontFamily="Segoe UI"
                    FontAttributes="Bold"
                    HeightRequest="48"/>

            <Button x:Name="RequestsBtn"
                    Text="My Requests"
                    Command="{Binding GoToRequestsCommand}"
                    BackgroundColor="#D8121B"
                    TextColor="#FFFFFF"
                    CornerRadius="20"
                    FontFamily="Segoe UI"
                    FontAttributes="Bold"
                    HeightRequest="48"/>

            <Button x:Name="SessionsBtn"
                    Text="My Sessions"
                    Command="{Binding GoToSessionsCommand}"
                    BackgroundColor="#0E1626"
                    TextColor="#FFFFFF"
                    CornerRadius="20"
                    FontFamily="Segoe UI"
                    FontAttributes="Bold"
                    HeightRequest="48"/>

            <Button x:Name="FeedbackBtn"
                    Text="Feedback"
                    Command="{Binding GoToFeedbackCommand}"
                    BackgroundColor="#D8121B"
                    TextColor="#FFFFFF"
                    CornerRadius="20"
                    FontFamily="Segoe UI"
                    FontAttributes="Bold"
                    HeightRequest="48"/>

            <!-- Logout Button -->
            <Button x:Name="LogoutBtn"
                    Text="Log Out"
                    Command="{Binding LogoutCommand}"
                    BackgroundColor="Transparent"
                    TextColor="#D8121B"
                    BorderColor="#D8121B"
                    BorderWidth="2"
                    CornerRadius="20"
                    FontFamily="Segoe UI"
                    FontAttributes="Bold"
                    HeightRequest="44"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
