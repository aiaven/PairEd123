<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="PairEd123.Views.FeedbackPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:PairEd123.Models"
    x:Name="RootPage"
    Title="Feedback"
    BackgroundColor="#F8FAFC">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <!-- Tab Buttons -->
            <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                <Button Text="To Review"
                        Command="{Binding ShowToReviewTabCommand}"
                        BackgroundColor="#D8121B"
                        TextColor="#FFFFFF"
                        CornerRadius="20"
                        FontFamily="Segoe UI"
                        FontAttributes="Bold"
                        HeightRequest="40"/>
                <Button Text="Given"
                        Command="{Binding ShowGivenTabCommand}"
                        BackgroundColor="#0E1626"
                        TextColor="#FFFFFF"
                        CornerRadius="20"
                        FontFamily="Segoe UI"
                        FontAttributes="Bold"
                        HeightRequest="40"/>
                <Button Text="Received"
                        Command="{Binding ShowReceivedTabCommand}"
                        BackgroundColor="Transparent"
                        TextColor="#D8121B"
                        BorderColor="#D8121B"
                        BorderWidth="2"
                        CornerRadius="20"
                        FontFamily="Segoe UI"
                        FontAttributes="Bold"
                        HeightRequest="40"/>
            </HorizontalStackLayout>

            <!-- Loading Indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#D8121B"/>

            <!-- Status Message -->
            <Label Text="{Binding StatusMessage}"
                   FontFamily="Segoe UI"
                   TextColor="#D8121B"
                   FontSize="14"
                   HorizontalOptions="Center"/>

            <!-- To Review Tab -->
            <CollectionView ItemsSource="{Binding SessionsToReview}" IsVisible="{Binding IsToReviewTabActive}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:SessionToReview">
                        <Frame BackgroundColor="#FFFFFF"
                               BorderColor="#E2E8F0"
                               CornerRadius="12"
                               Padding="16"
                               HasShadow="True"
                               Margin="0,6">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding OtherPartyName}"
                                       FontFamily="Segoe UI"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#0E1626"/>
                                <Label Text="{Binding Subject}"
                                       FontFamily="Segoe UI"
                                       FontSize="14"
                                       TextColor="#64748B"/>
                                <Label Text="{Binding ScheduledTime, StringFormat='{0:MMM d, yyyy h:mm tt}'}"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       TextColor="#64748B"/>
                                <Button Text="Leave Feedback"
                                        Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.StartReviewCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#D8121B"
                                        TextColor="#FFFFFF"
                                        CornerRadius="20"
                                        FontFamily="Segoe UI"
                                        FontAttributes="Bold"
                                        HeightRequest="36"/>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Given Feedback Tab -->
            <CollectionView ItemsSource="{Binding GivenFeedback}" IsVisible="{Binding IsGivenTabActive}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:FeedbackDisplay">
                        <Frame BackgroundColor="#FFFFFF"
                               BorderColor="#E2E8F0"
                               CornerRadius="12"
                               Padding="16"
                               HasShadow="True"
                               Margin="0,6">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding OtherPartyName}"
                                       FontFamily="Segoe UI"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#0E1626"/>
                                <Label Text="{Binding Subject}"
                                       FontFamily="Segoe UI"
                                       FontSize="14"
                                       TextColor="#64748B"/>
                                <Label Text="{Binding Rating, StringFormat='Rating: {0}/5'}"
                                       FontFamily="Segoe UI"
                                       FontSize="14"
                                       TextColor="#0E1626"/>
                                <Label Text="{Binding Comment}"
                                       FontFamily="Segoe UI"
                                       FontSize="14"
                                       TextColor="#0E1626"/>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Received Feedback Tab -->
            <CollectionView ItemsSource="{Binding ReceivedFeedback}" IsVisible="{Binding IsReceivedTabActive}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:FeedbackDisplay">
                        <Frame BackgroundColor="#FFFFFF"
                               BorderColor="#E2E8F0"
                               CornerRadius="12"
                               Padding="16"
                               HasShadow="True"
                               Margin="0,6">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding OtherPartyName}"
                                       FontFamily="Segoe UI"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#0E1626"/>
                                <Label Text="{Binding Subject}"
                                       FontFamily="Segoe UI"
                                       FontSize="14"
                                       TextColor="#64748B"/>
                                <Label Text="{Binding Rating, StringFormat='Rating: {0}/5'}"
                                       FontFamily="Segoe UI"
                                       FontSize="14"
                                       TextColor="#0E1626"/>
                                <Label Text="{Binding Comment}"
                                       FontFamily="Segoe UI"
                                       FontSize="14"
                                       TextColor="#0E1626"/>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Review Prompt -->
            <Frame IsVisible="{Binding IsReviewPromptVisible}"
                   BackgroundColor="#FFFFFF"
                   BorderColor="#E2E8F0"
                   CornerRadius="12"
                   Padding="16"
                   HasShadow="True">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Rate this session"
                           FontFamily="Segoe UI"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#0E1626"/>
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="1" CommandParameter="1" Command="{Binding SetRatingCommand}"
                                BackgroundColor="#0E1626" TextColor="#FFFFFF" CornerRadius="20" HeightRequest="36"/>
                        <Button Text="2" CommandParameter="2" Command="{Binding SetRatingCommand}"
                                BackgroundColor="#0E1626" TextColor="#FFFFFF" CornerRadius="20" HeightRequest="36"/>
                        <Button Text="3" CommandParameter="3" Command="{Binding SetRatingCommand}"
                                BackgroundColor="#0E1626" TextColor="#FFFFFF" CornerRadius="20" HeightRequest="36"/>
                        <Button Text="4" CommandParameter="4" Command="{Binding SetRatingCommand}"
                                BackgroundColor="#0E1626" TextColor="#FFFFFF" CornerRadius="20" HeightRequest="36"/>
                        <Button Text="5" CommandParameter="5" Command="{Binding SetRatingCommand}"
                                BackgroundColor="#0E1626" TextColor="#FFFFFF" CornerRadius="20" HeightRequest="36"/>
                    </HorizontalStackLayout>
                    <Label Text="{Binding SelectedRating, StringFormat='Selected: {0}/5'}"
                           FontFamily="Segoe UI"
                           FontSize="14"
                           TextColor="#64748B"/>
                    <Entry Placeholder="Optional comment"
                           Text="{Binding ReviewCommentText}"
                           FontFamily="Segoe UI"
                           TextColor="#0E1626"
                           PlaceholderColor="#64748B"/>
                    <HorizontalStackLayout Spacing="12">
                        <Button Text="Submit"
                                Command="{Binding ConfirmReviewCommand}"
                                BackgroundColor="#D8121B"
                                TextColor="#FFFFFF"
                                CornerRadius="20"
                                FontFamily="Segoe UI"
                                FontAttributes="Bold"
                                HeightRequest="40"/>
                        <Button Text="Cancel"
                                Command="{Binding CancelReviewCommand}"
                                BackgroundColor="Transparent"
                                TextColor="#0E1626"
                                BorderColor="#0E1626"
                                BorderWidth="2"
                                CornerRadius="20"
                                FontFamily="Segoe UI"
                                FontAttributes="Bold"
                                HeightRequest="40"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
