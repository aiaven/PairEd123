<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="PairEd123.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:PairEd123"
    xmlns:views="clr-namespace:PairEd123.Views"
    Shell.FlyoutBehavior="Disabled"
    Title="PairEd123">
    <ShellContent Title="Login" ContentTemplate="{DataTemplate views:LoginPage}" Route="LoginPage" />
    <ShellContent Title="Dashboard" ContentTemplate="{DataTemplate views:UserDashboardPage}" Route="UserDashboardPage" />
    <ShellContent Title="Admin Dashboard" ContentTemplate="{DataTemplate views:AdminDashboardPage}" Route="AdminDashboardPage" />
    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />
</Shell>